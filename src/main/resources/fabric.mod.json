{
	"schemaVersion": 1,
	"id": "goldendandelionindicator",
	"version": "${version}",
	"name": "GoldenDandelionIndicator",
	"description": "Shows particles above mobs effected by the Golden Dandelion.",
	"authors": [
		"bottledpepsi"
	],
	"contact": {
		"homepage": "https://bottledpepsi.github.io/",
		"sources": "https://github.com/bottledpepsi/golden-dandelion-indicator/"
	},
	"license": "GPL-3.0",
	"icon": "assets/goldendandelionindicator/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"net.bottledpepsi.gdi.GoldenDandelionIndicator"
		],
		"client": [
			"net.bottledpepsi.gdi.GoldenDandelionIndicatorClient"
		]
	},
	"mixins": [
		"goldendandelionindicator.mixins.json",
		{
			"config": "goldendandelionindicator.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": ">=26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
